\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{eng-macros}[2026/04/26 Engineering cross-domain notation]

% === Sets and number systems ===
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\C}{\mathbb{C}}
\newcommand{\F}{\mathbb{F}}

% === Probability and statistics ===
\renewcommand{\Pr}{\mathbb{P}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\Var}{\operatorname{Var}}
\newcommand{\Cov}{\operatorname{Cov}}
\newcommand{\Cor}{\operatorname{Cor}}

% === Vectors, matrices, tensors ===
\newcommand{\vect}[1]{\bm{#1}}
\newcommand{\mat}[1]{\bm{#1}}
\newcommand{\tens}[1]{\bm{\mathsf{#1}}}
\newcommand{\unitvec}[1]{\hat{\bm{#1}}}
\newcommand{\transpose}{^{\mathsf{T}}}
\newcommand{\inv}{^{-1}}

% === Calculus and operators ===
\newcommand{\dd}{\mathop{}\!\mathrm{d}}
\newcommand{\dv}[2]{\frac{\dd #1}{\dd #2}}
\newcommand{\pdv}[2]{\frac{\partial #1}{\partial #2}}
\newcommand{\grad}{\nabla}
\newcommand{\divg}{\nabla\cdot}
\newcommand{\curl}{\nabla\times}
\newcommand{\laplacian}{\nabla^{2}}

% === Norms and absolute values ===
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclarePairedDelimiter{\inner}{\langle}{\rangle}
\DeclarePairedDelimiter{\set}{\{}{\}}

% === Common physical and engineering symbols ===
\newcommand{\degC}{\si{\degreeCelsius}}
\newcommand{\degK}{\si{\kelvin}}

% === Order of magnitude ===
\newcommand{\oom}[1]{\mathcal{O}\!\left(#1\right)}

% === Fluents and flows ===
\newcommand{\flux}[1]{\bm{J}_{#1}}
\newcommand{\stress}{\sigma}
\newcommand{\strain}{\varepsilon}

% === Information theory ===
\newcommand{\Hent}{\mathrm{H}}                  % Shannon entropy
\newcommand{\Imut}{\mathrm{I}}                  % mutual information
\newcommand{\KL}{D_{\mathrm{KL}}}

% === Common engineering fonts and emphasis ===
\newcommand{\engterm}[1]{\textbf{#1}}
\newcommand{\engdef}[1]{\textit{#1}}
\newcommand{\engunit}[1]{\textsf{#1}}

% === Margin notes for editorial markers (Phase-0 placeholder convention) ===
\newcommand{\TODO}[1]{\textcolor{engred}{[\textbf{TODO:} #1]}}

\endinput
