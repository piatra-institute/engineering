  year      = {1678},
  address   = {London},
  note      = {The anagram \emph{ceiiinosssttuv}, published 1676, decoded in 1678 as \emph{ut tensio sic vis}: ``as the extension, so the force.'' The founding statement of linear elasticity.}
}

@book{hist:archimedes-equilibrium,
  author    = {Archimedes},
  title     = {On the Equilibrium of Planes, or The Centres of Gravity of Planes, Book I},
  publisher = {Cambridge University Press},
  year      = {1897},
  address   = {Cambridge},
  editor    = {Heath, Thomas Little},
  note      = {In \emph{The Works of Archimedes}, edited in modern notation, with introductory chapters, by T.\ L.\ Heath. The two books on the equilibrium of planes are the founding text of theoretical statics.}
}

@book{hist:archimedes-floating,
  author    = {Archimedes},
  title     = {On Floating Bodies, Books I and II},
  publisher = {Cambridge University Press},
  year      = {1897},
  address   = {Cambridge},
  editor    = {Heath, Thomas Little},
  note      = {In \emph{The Works of Archimedes}, edited in modern notation by T.\ L.\ Heath. Book I states the conditions of equilibrium of a body in a heavy fluid (the principle now called Archimedes' principle); Book II analyses the stability of floating paraboloids, the founding theoretical treatment of metacentric stability.}
}

@book{hist:bernoulli1738,
  author    = {Bernoulli, Daniel},
  title     = {Hydrodynamics, or Commentaries on the Forces and Motions of Fluids},
  publisher = {Dover Publications},
  year      = {1968},
  address   = {New York},
  editor    = {Carmody, Thomas and Kobus, Helmut},
  note      = {English translation by Thomas Carmody and Helmut Kobus of \emph{Hydrodynamica, sive de Viribus et Motibus Fluidorum Commentarii}, first published Strasbourg 1738. The founding text of theoretical fluid mechanics; Section XII gives the velocity-pressure relation now called Bernoulli's equation in terms of velocity and pressure heads.}
}

@book{hist:coulomb1781,
  author    = {Coulomb, Charles-Augustin de},
  title     = {Th\'eorie des machines simples, en ayant \'egard au frottement de leurs parties et \`a la roideur des cordages},
  publisher = {M\'emoires de Math\'ematique et de Physique de l'Acad\'emie Royale des Sciences},
  year      = {1781},
  address   = {Paris},
  note      = {Prize memoir of 1781, published 1785. Foundational empirical study of dry friction and rope stiffness; the source for what is now called Coulomb friction.}
}

@book{hist:newton1687,
  author    = {Newton, Isaac},
  title     = {The Principia: Mathematical Principles of Natural Philosophy},
  publisher = {University of California Press},
  year      = {1999},
  address   = {Berkeley},
  note      = {Translated by I.\ Bernard Cohen and Anne Whitman, with assistance from Julia Budenz. A new translation of \emph{Philosophiae Naturalis Principia Mathematica}, first published 1687.}
}

@book{hist:pascal1663,
  author    = {Pascal, Blaise},
  title     = {The Physical Treatises of Pascal: The Equilibrium of Liquids and the Weight of the Mass of the Air},
  publisher = {Columbia University Press},
  year      = {1937},
  address   = {New York},
  editor    = {Spiers, I.\ H.\ B. and Spiers, A.\ G.\ H.},
  note      = {English translation by I.\ H.\ B.\ and A.\ G.\ H.\ Spiers, with introduction and notes by Fr\'ederic Barry, of the \emph{Trait\'e de l'\'equilibre des liqueurs et de la pesanteur de la masse de l'air}, first published Paris 1663. The founding theoretical and experimental statement of hydrostatic pressure and Pascal's principle of pressure transmission in confined fluids.}
}

@book{hist:carnot1824,
  author    = {Carnot, Sadi},
  title     = {Reflections on the Motive Power of Fire, and on Machines Fitted to Develop That Power},
  publisher = {Dover Publications},
  year      = {1960},
  address   = {New York},
  editor    = {Mendoza, E.},
  note      = {English translation by R.\ H.\ Thurston of \emph{R\'eflexions sur la puissance motrice du feu et sur les machines propres \`a d\'evelopper cette puissance}, first published Paris 1824. The founding text of thermodynamics: introduces the reversible heat engine, identifies the temperature-only dependence of maximum efficiency, and frames the second law in its earliest form. Reprinted with related papers of Clapeyron and Clausius in the Mendoza edition.}
}

@article{hist:clausius1850,
  author  = {Clausius, Rudolf},
  title   = {{\"U}ber die bewegende Kraft der W\"arme und die Gesetze, welche sich daraus f\"ur die W\"armelehre selbst ableiten lassen},
  journal = {Annalen der Physik und Chemie},
  volume  = {79},
  pages   = {368--397, 500--524},
  year    = {1850},
  note    = {English translation ``On the Motive Power of Heat, and on the Laws which can be deduced from it for the Theory of Heat'' in Magie, \emph{A Source Book in Physics}, McGraw-Hill 1935, pp.\ 228--236. The founding text of the second law in its modern form; introduces the statement that heat cannot, of itself, pass from a cooler to a hotter body.}
}

@book{hist:fourier1822,
  author    = {Fourier, Joseph},
  title     = {The Analytical Theory of Heat},
  publisher = {Cambridge University Press},
  year      = {1878},
  address   = {Cambridge},
  editor    = {Freeman, Alexander},
  note      = {English translation by Alexander Freeman of \emph{Th\'eorie analytique de la chaleur}, first published Paris 1822. The founding text of heat-transfer theory and of harmonic analysis; develops the heat equation and the Fourier series as tools for its solution.}
}

@book{hist:boltzmann1896,
  author    = {Boltzmann, Ludwig},
  title     = {Lectures on Gas Theory},
  publisher = {University of California Press},
  year      = {1964},
  address   = {Berkeley},
  editor    = {Brush, Stephen G.},
  note      = {English translation by Stephen G.\ Brush of \emph{Vorlesungen \"uber Gastheorie}, first published Leipzig 1896--1898. Boltzmann's mature statement of the kinetic theory of gases, the H-theorem, and the statistical interpretation of entropy as $S = k \log W$.}
}

@book{hist:maxwell1873,
  author    = {Maxwell, James Clerk},
  title     = {A Treatise on Electricity and Magnetism},
  publisher = {Clarendon Press},
  edition   = {3rd},
  year      = {1892},
  address   = {Oxford},
