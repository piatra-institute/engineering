}

@book{hist:hertz1893,
  author    = {Hertz, Heinrich},
  title     = {Electric Waves: Being Researches on the Propagation of Electric Action with Finite Velocity through Space},
  publisher = {Macmillan and Co.},
  year      = {1893},
  address   = {London},
  editor    = {Jones, D.\ E.},
  note      = {English translation by D.\ E.\ Jones of \emph{Untersuchungen \"uber die Ausbreitung der elektrischen Kraft}, Leipzig 1892. Collected experimental papers (1887--1891) that empirically established the existence and propagation properties of electromagnetic waves predicted by Maxwell.}
}

@article{hist:mendeleev1869,
